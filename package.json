{
  "name": "code-machina",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "daisyui": "^2.18.0",
    "postcss": "^8.4.5",
    "prettier": "latest",
    "prettier-plugin-tailwindcss": "^0.1.11",
    "tailwindcss": "^3.0.7",
    "turbo": "latest"
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=14.0.0"
  }
}
